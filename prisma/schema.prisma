generator client {
  provider = "prisma-client"
  output   = "generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model pdf {
  id         String      @id @default(uuid()) @db.Uuid
  file_name  String      @db.VarChar(100)
  created_at DateTime    @default(now())
  pdf_chunks pdf_chunk[]
}

model pdf_chunk {
  id          String   @id @default(uuid()) @db.Uuid
  pdf_id      String   @db.Uuid
  pdf         pdf      @relation(fields: [pdf_id], references: [id], onDelete: Cascade)
  chunk_text  String
  chunk_index Int
  embedding   Unsupported("vector(768)") //embedding index applied with migration files

  @@index([pdf_id])
}
