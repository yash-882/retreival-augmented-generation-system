generator client {
  provider = "prisma-client"
  output   = "generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model pdf {
  id         String      @id @default(uuid()) @db.Uuid
  file_name  String      @db.VarChar(100)
  created_at DateTime    @default(now())
  pdf_chunks pdf_chunk[]
  user_id    String      @db.Uuid
  user       user        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  file_hash  String      @db.VarChar(100)

  @@index([user_id]) // for querying user's all pdfs
  @@index([id, user_id]) // for querying user's specific pdfs
}

model pdf_chunk {
  id          String                     @id @default(uuid()) @db.Uuid
  pdf_id      String                     @db.Uuid
  pdf         pdf                        @relation(fields: [pdf_id], references: [id], onDelete: Cascade)
  chunk_text  String
  chunk_index Int
  embedding   Unsupported("vector(768)") //embedding index applied with migration files
  user_id     String                     @db.Uuid

  @@index([user_id]) // for querying user's pdf's chunks
}

model user {
  id         String   @id @default(uuid()) @db.Uuid
  email      String   @unique @db.VarChar(255)
  password   String   @db.VarChar(70)
  name       String   @default("default_name") @db.VarChar(50)
  created_at DateTime @default(now())
  pdfs       pdf[]
}

model conversation {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  created_at DateTime  @default(now())
  messages   message[]
}

enum Role {
  USER
  ASSISTANT
}

enum MessageType {
  NO_RESULT
  SUCCESS
}

model message {
  id              String       @id @default(uuid()) @db.Uuid
  seq             Int          @default(autoincrement()) // helps as a tiebreaker for message queries
  type            MessageType  @default(SUCCESS)
  conversation_id String       @db.Uuid
  content         String
  conversation    conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  role            Role 
  created_at      DateTime     @default(now())

  @@index([conversation_id]) // for querying conversation's messages
  @@index([created_at(sort: Desc), seq(sort: Desc)]) // for cursor based pagination on messages
}
